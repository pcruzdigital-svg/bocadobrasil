<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Boca do Brasil | Haz tu pedido</title>
  <style>
    :root {
      --bg: #f5f6f8;
      --card: #ffffff;
      --text: #16181d;
      --muted: #6e7685;
      --primary: #25d366;
      --primary-dark: #1daa50;
      --accent: #ff7a00;
      --shadow: 0 10px 30px rgba(16, 24, 40, 0.08);
      --radius: 18px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: "Inter", "Segoe UI", Roboto, Arial, sans-serif;
      background: linear-gradient(180deg, #fafafa 0%, var(--bg) 100%);
      color: var(--text);
      min-height: 100vh;
      padding-bottom: 100px;
    }

    .container {
      width: min(1100px, 92%);
      margin: 0 auto;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 20;
      backdrop-filter: blur(10px);
      background: rgba(250, 250, 250, 0.9);
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .header-content {
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 18px 0;
    }

    .brand {
      font-size: clamp(1.2rem, 2vw, 1.6rem);
      font-weight: 800;
      letter-spacing: 0.2px;
    }

    .subtitle {
      color: var(--muted);
      font-size: 0.95rem;
      font-weight: 500;
    }

    .hero {
      margin: 22px auto 14px;
      background: radial-gradient(circle at top right, #ffe3cc 0, transparent 34%), var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,.04);
    }

    .hero h1 {
      font-size: clamp(1.3rem, 5vw, 2rem);
      line-height: 1.15;
      margin-bottom: 8px;
    }

    .hero p {
      color: var(--muted);
      max-width: 420px;
      font-size: 0.95rem;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: #fff5eb;
      color: #9b4d00;
      font-size: 0.82rem;
      font-weight: 700;
      border: 1px solid #ffd8b1;
      margin-bottom: 10px;
    }

    .badge::before {
      content: "★";
      color: var(--accent);
    }

    .hero-emoji {
      font-size: clamp(2.6rem, 7vw, 4rem);
      filter: drop-shadow(0 8px 12px rgba(0, 0, 0, 0.12));
      animation: float 2.8s ease-in-out infinite;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    .products {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      margin: 16px 0 24px;
    }

    .card {
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid rgba(0,0,0,.04);
      overflow: hidden;
      transition: transform .2s ease, box-shadow .2s ease;
      display: grid;
      grid-template-rows: 190px auto;
    }

    .card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(16, 24, 40, 0.12);
    }

    .card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .card-body {
      padding: 14px;
      display: grid;
      gap: 10px;
    }

    .product-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
    }

    .name {
      font-size: 1.03rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .price {
      color: #0b7e37;
      font-weight: 800;
      white-space: nowrap;
      font-size: 0.98rem;
    }

    .description {
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.4;
    }

    .quantity {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #f1f3f7;
      width: fit-content;
      border-radius: 999px;
      padding: 4px;
    }

    .qty-btn {
      width: 34px;
      height: 34px;
      border: 0;
      border-radius: 999px;
      background: #fff;
      font-size: 1.2rem;
      cursor: pointer;
      color: #202530;
      transition: transform .12s ease, background .2s ease;
      box-shadow: 0 2px 6px rgba(0,0,0,.08);
    }

    .qty-btn:hover {
      background: #ebeff5;
    }

    .qty-btn:active {
      transform: scale(0.92);
    }

    .qty-value {
      min-width: 28px;
      text-align: center;
      font-weight: 700;
      font-size: 0.95rem;
      transition: transform .15s ease;
    }

    .qty-value.pop {
      transform: scale(1.22);
    }

    .whatsapp-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 30;
      background: rgba(245, 246, 248, 0.9);
      backdrop-filter: blur(8px);
      border-top: 1px solid rgba(0,0,0,.06);
      padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
    }

    .whatsapp-btn {
      width: min(1100px, 100%);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: linear-gradient(180deg, #2be16f 0%, var(--primary) 100%);
      color: #fff;
      border: none;
      border-radius: 14px;
      font-size: 1rem;
      font-weight: 800;
      padding: 15px 16px;
      cursor: pointer;
      box-shadow: 0 10px 24px rgba(37, 211, 102, 0.33);
      transition: transform .15s ease, filter .2s ease;
    }

    .whatsapp-btn:hover {
      filter: brightness(0.98);
    }

    .whatsapp-btn:active {
      transform: translateY(2px);
    }

    .whatsapp-btn:disabled {
      background: #b6bdca;
      box-shadow: none;
      cursor: not-allowed;
    }

    .item-count {
      margin-left: 4px;
      font-size: 0.9rem;
      background: rgba(255,255,255,.2);
      padding: 2px 8px;
      border-radius: 999px;
    }

    @media (min-width: 680px) {
      .products {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .hero {
        padding: 24px;
      }
    }

    @media (min-width: 980px) {
      .products {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>
</head>
<body>
  <header>
    <div class="container header-content">
      <div class="brand">Boca do Brasil</div>
      <div class="subtitle">Haz tu pedido</div>
    </div>
  </header>

  <main class="container">
    <section class="hero" aria-label="Presentación del menú">
      <div>
        <span class="badge">Sabor auténtico brasileño</span>
        <h1>Haz tu pedido en segundos 🚀</h1>
        <p>Selecciona tus favoritos, ajusta la cantidad y envía tu pedido directo por WhatsApp con un solo toque.</p>
      </div>
      <div class="hero-emoji" aria-hidden="true">🍽️</div>
    </section>

    <section class="products" id="products" aria-label="Lista de productos"></section>
  </main>

  <div class="whatsapp-bar">
    <button class="whatsapp-btn" id="sendOrderBtn" type="button">
      Enviar pedido por WhatsApp <span class="item-count" id="itemCount">0</span>
    </button>
  </div>

  <script>
    const products = [
      {
        id: "coxinha",
        name: "Coxinha",
        price: 2.8,
        image: "https://images.unsplash.com/photo-1625944234511-df8f3dcbf2f0?auto=format&fit=crop&w=1200&q=80",
        description: "Masa crujiente rellena de pollo cremoso."
      },
      {
        id: "pao-de-queijo",
        name: "Pão de queijo",
        price: 1.9,
        image: "https://images.unsplash.com/photo-1604908176997-43134db95f6d?auto=format&fit=crop&w=1200&q=80",
        description: "Panecillos de queso suaves por dentro y dorados por fuera."
      },
      {
        id: "brigadeiro",
        name: "Brigadeiro",
        price: 1.5,
        image: "https://images.unsplash.com/photo-1599785209707-a7a4f0e4ff6d?auto=format&fit=crop&w=1200&q=80",
        description: "Dulce clásico de chocolate con granillo."
      },
      {
        id: "acai",
        name: "Açaí bowl",
        price: 6.9,
        image: "https://images.unsplash.com/photo-1498837167922-ddd27525d352?auto=format&fit=crop&w=1200&q=80",
        description: "Açaí frío con frutas frescas y granola premium."
      },
      {
        id: "feijoada",
        name: "Feijoada",
        price: 12.5,
        image: "https://images.unsplash.com/photo-1627308595171-d1b5d1981b1c?auto=format&fit=crop&w=1200&q=80",
        description: "Plato tradicional brasileño con arroz y guarniciones."
      },
      {
        id: "guarana",
        name: "Guaraná lata",
        price: 2.2,
        image: "https://images.unsplash.com/photo-1613478223719-2ab802602423?auto=format&fit=crop&w=1200&q=80",
        description: "Refresco brasileño frío y refrescante."
      }
    ];

    const quantities = Object.fromEntries(products.map(product => [product.id, 0]));

    const productsContainer = document.getElementById("products");
    const sendOrderBtn = document.getElementById("sendOrderBtn");
    const itemCount = document.getElementById("itemCount");

    const euro = new Intl.NumberFormat("es-ES", {
      style: "currency",
      currency: "EUR"
    });

    function renderProducts() {
      productsContainer.innerHTML = products.map(product => `
        <article class="card" data-id="${product.id}">
          <img src="${product.image}" alt="${product.name}" loading="lazy" />
          <div class="card-body">
            <div class="product-row">
              <div class="name">${product.name}</div>
              <div class="price">${euro.format(product.price)}</div>
            </div>
            <p class="description">${product.description}</p>
            <div class="quantity" role="group" aria-label="Cantidad de ${product.name}">
              <button class="qty-btn" data-action="decrease" data-id="${product.id}" aria-label="Reducir ${product.name}">−</button>
              <span class="qty-value" id="qty-${product.id}">0</span>
              <button class="qty-btn" data-action="increase" data-id="${product.id}" aria-label="Aumentar ${product.name}">+</button>
            </div>
          </div>
        </article>
      `).join("");
    }

    function updateSummaryState() {
      const totalItems = Object.values(quantities).reduce((sum, qty) => sum + qty, 0);
      itemCount.textContent = String(totalItems);
      sendOrderBtn.disabled = totalItems === 0;
    }

    function animateQty(id) {
      const el = document.getElementById(`qty-${id}`);
      if (!el) return;
      el.classList.remove("pop");
      requestAnimationFrame(() => {
        el.classList.add("pop");
        setTimeout(() => el.classList.remove("pop"), 140);
      });
    }

    function adjustQuantity(id, delta) {
      const next = Math.max(0, quantities[id] + delta);
      if (next === quantities[id]) return;
      quantities[id] = next;
      const qtyEl = document.getElementById(`qty-${id}`);
      if (qtyEl) qtyEl.textContent = String(next);
      animateQty(id);
      updateSummaryState();
    }

    function buildMessage() {
      const selected = products.filter(product => quantities[product.id] > 0);
      if (!selected.length) return "";

      const lines = selected.map(product => `${product.name} x${quantities[product.id]}`);
      return `Hola, quiero pedir:%0A%0A${lines.join("%0A")}`;
    }

    productsContainer.addEventListener("click", event => {
      const btn = event.target.closest("button[data-action]");
      if (!btn) return;

      const { action, id } = btn.dataset;
      adjustQuantity(id, action === "increase" ? 1 : -1);
    });

    sendOrderBtn.addEventListener("click", () => {
      const messageRaw = buildMessage();
      if (!messageRaw) {
        sendOrderBtn.animate(
          [
            { transform: "translateX(0)" },
            { transform: "translateX(-6px)" },
            { transform: "translateX(6px)" },
            { transform: "translateX(0)" }
          ],
          { duration: 220, easing: "ease" }
        );
        return;
      }

      const message = encodeURIComponent(messageRaw.replace(/%0A/g, "\n"));
      const url = `https://wa.me/346611878234?text=${message}`;
      window.open(url, "_blank", "noopener");
    });

    renderProducts();
    updateSummaryState();
  </script>
</body>
</html>
